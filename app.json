{
  "expo": {
    "name": "Navipad",
    "slug": "navipad",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "navipad",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "transparent"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.navipad.app",
      "config": {
        "googleMapsApiKey": "AIzaSyCRyntmD7dGu3X8j4FPMmfXXNMeTrrmDGY"
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Navipad a besoin d'accéder à votre position pour afficher votre localisation sur la carte.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Navipad a besoin d'accéder à votre position pour afficher votre localisation sur la carte.",
        "NSCameraUsageDescription": "Navipad a besoin d'accéder à votre caméra pour prendre des photos.",
        "NSPhotoLibraryUsageDescription": "Navipad a besoin d'accéder à votre galerie photo pour sélectionner des images et vidéos.",
        "NSMicrophoneUsageDescription": "Navipad a besoin d'accéder au microphone pour enregistrer des vidéos avec du son.",
        "NSDocumentsFolderUsageDescription": "Navipad a besoin d'accéder aux documents pour sélectionner des fichiers."
      }
    },
    "android": {
      "package": "com.navipad.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "transparent"
      },
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.INTERNET",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.MANAGE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyCRyntmD7dGu3X8j4FPMmfXXNMeTrrmDGY"
        }
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-location",
      "expo-image-picker",
      "expo-document-picker",
      "expo-av",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "backgroundColor": "transparent"
        }
      ],
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "cb23acec-f2a0-4d92-a27b-0c56975749f6"
      }
    }
  }
}
